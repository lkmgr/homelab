{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>lkmgr/homelab//.renovate/autoMerge.json5",
    "github>lkmgr/homelab//.renovate/customManagers.json5",
    "github>lkmgr/homelab//.renovate/groups.json5",
    "github>lkmgr/homelab//.renovate/labels.json5",
    "github>lkmgr/homelab//.renovate/semanticCommits.json5",
    ":configMigration",
    ":automergeBranch",
    ":disableRateLimiting",
    ":semanticCommits",
    ":timezone(Europe/Berlin)",
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  ignorePaths: ["**/*.sops.*"],
  flux: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  helmfile: {
    managerFilePatterns: [
      "/(^|/)helmfile\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
      "/(^|/)helmfile\\.d/.+\\.ya?ml(?:\\.gotmpl)?(?:\\.j2)?$/",
    ],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  kustomize: {
    managerFilePatterns: ["/^kustomization\\.ya?ml(?:\\.j2)?$/"],
  },
  // "helm-values": {
  //   managerFilePatterns: [
  //     "/(^|/)ansible/.+\\.ya?ml(\\.j2)?$/",
  //     "/(^|/)kubernetes/.+\\.ya?ml$/",
  //   ],
  //   pinDigests: true,
  // },
  npm: {
    rangeStrategy: "pin",
  },
  packageRules: [
    {
      description: "Override Helmfile Dependency Name",
      matchDatasources: ["docker"],
      matchManagers: ["helmfile"],
      overrideDepName: "{{packageName}}",
    },
  ],
}
