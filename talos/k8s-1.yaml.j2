---
machine:
  install:
    disk: /dev/disk/by-id/ata-SK_hynix_SC308_SATA_256GB_FJ6CN66471050CT50
    image: factory.talos.dev/installer/4b3cd373a192c8469e859b7a0cfbed3ecc3577c4a2d346a37b0aeff9cd17cdb0:{{ versions.talos }}
  nodeLabels:
    node.longhorn.io/create-default-disk: true
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: k8s-1
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
  match: glob("14:b3:1f:04:*", mac(link.permanent_addr))
---
apiVersion: v1alpha1
kind: VLANConfig
name: net0.4
vlanID: 4
parent: net0
mtu: 1500
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: net0.4
clientIdentifier: mac
---
apiVersion: v1alpha1
kind: Layer2VIPConfig
name: {{ kubernetes.api.addr }}
link: net0.4
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: local-hostpath
volumeType: partition
provisioning:
  diskSelector:
    match: '"/dev/disk/by-id/nvme-CT500P3SSD8_2328E6ED8EDC" in disk.symlinks'
  minSize: 100GiB
  maxSize: 100GiB
---
apiVersion: v1alpha1
kind: UserVolumeConfig
name: longhorn
volumeType: partition
provisioning:
  diskSelector:
    match: '"/dev/disk/by-id/nvme-CT500P3SSD8_2328E6ED8EDC" in disk.symlinks'
  minSize: 100GiB
  grow: true
